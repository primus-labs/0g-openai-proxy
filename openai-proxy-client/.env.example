# Service port
PORT=8080

# Required: Upstream API key (for example, a DeepSeek API key)
OPENAI_API_KEY=your_api_key_here

# Upstream API base URL (includes /v1)
OPENAI_API_BASE=https://api.deepseek.com/v1

# Model to send to upstream API
UPSTREAM_MODEL=deepseek-chat

# Primus zkTLS (required). ZKTLS_APP_SECRET must be a valid hex private key for signing.
ZKTLS_APP_ID=
ZKTLS_APP_SECRET=
# Optional: ZKTLS_USER_ADDRESS=0x0000000000000000000000000000000000000000
# Optional: ZKTLS_INIT_MODE=auto
# Optional: ZKTLS_MIN_WORKERS=2
# Optional: ZKTLS_MAX_WORKERS=4
# Optional: ZKTLS_TASK_TIMEOUT_MS=600000
# Optional: ZKTLS_MAX_QUEUE_SIZE=100
# Optional: ZKTLS_IDLE_SHRINK_MS=30000
